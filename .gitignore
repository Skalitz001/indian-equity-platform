# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging outputs
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Test and coverage outputs
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Local environment and secrets
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Logs and runtime files
*.log
logs/
*.pid
*.tmp
*.temp

# Local market data and generated datasets
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Model artifacts, reports, and prediction exports
artifacts/*
!artifacts/.gitkeep

# Notebook checkpoints
.ipynb_checkpoints/

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
